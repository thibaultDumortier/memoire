    <rdf:Description rdf:about="http://arxiv.org/abs/2208.11194">
        <z:itemType>preprint</z:itemType>
        <dc:publisher>
           <foaf:Organization><foaf:name>arXiv</foaf:name></foaf:Organization>
        </dc:publisher>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Tan</foaf:surname>
                        <foaf:givenName>Weiting</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Koehn</foaf:surname>
                        <foaf:givenName>Philipp</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
            </rdf:Seq>
        </bib:authors>
        <dcterms:isReferencedBy rdf:resource="#item_64"/>
        <link:link rdf:resource="#item_36"/>
        <dc:relation rdf:resource="https://github.com/steventan0110/align-filter"/>
        <dc:subject>
            <z:AutomaticTag>
               <rdf:value>Computer Science - Computation and Language</rdf:value>
            </z:AutomaticTag>
        </dc:subject>
        <dc:subject>EN</dc:subject>
        <dc:subject>data-mining</dc:subject>
        <dc:subject>Bitext</dc:subject>
        <dc:title>Bitext Mining for Low-Resource Languages via Contrastive Learning</dc:title>
        <dcterms:abstract>Mining high-quality bitexts for low-resource languages is challenging. This paper shows that sentence representation of language models fine-tuned with multiple negatives ranking loss, a contrastive objective, helps retrieve clean bitexts. Experiments show that parallel data mined from our approach substantially outperform the previous state-of-the-art method on low resource languages Khmer and Pashto.</dcterms:abstract>
        <dc:date>2022-08-23</dc:date>
        <z:libraryCatalog>arXiv.org</z:libraryCatalog>
        <dc:identifier>
            <dcterms:URI>
               <rdf:value>http://arxiv.org/abs/2208.11194</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2024-12-27 10:39:42</dcterms:dateSubmitted>
        <dc:description>arXiv:2208.11194 [cs]</dc:description>
        <dc:identifier>DOI 10.48550/arXiv.2208.11194</dc:identifier>
        <prism:number>arXiv:2208.11194</prism:number>
    </rdf:Description>
    <bib:Memo rdf:about="#item_64">
        <rdf:value>&lt;div data-schema-version=&quot;9&quot;&gt;&lt;p&gt;Les langues manipulées étant des langues peu dotées, ce papier est intéressant. En effet, il parle de l’utilisation de phrase de type sentence transformers dans la détection de phrases proches. Ce qui permettrait à un programme de faire du minage de bitext efficace pour des langues peu dotées.&lt;/p&gt;
&lt;/div&gt;</rdf:value>
    </bib:Memo>
