                        <foaf:surname>Steingrímsson</foaf:surname>
                        <foaf:givenName>Steinþór</foaf:givenName>
                    </foaf:Person>
                </rdf:li>
                <rdf:li>
                    <foaf:Person>
                        <foaf:surname>Lohar</foaf:surname>
                        <foaf:givenName>Pintu</foaf:givenName>
                    </foaf:Person>
